@page "/Users/Create"
@model LeveInvestimentos.Web.Pages.Users.CreateModel
@{
    ViewData["Title"] = "Criar Usuário";
}

<div class="uk-flex uk-flex-between uk-flex-middle uk-margin-bottom">
    <h3>Novo Usuário</h3>
    <a href="/Users" class="uk-button uk-button-default">Voltar</a>
</div>

<div class="uk-card uk-card-default uk-card-body">
    @if (!ModelState.IsValid)
    {
        <div class="uk-alert-danger" uk-alert>
            <div asp-validation-summary="All" class="uk-text-small"></div>
        </div>
    }

    <form method="post" class="uk-grid-small" uk-grid>
        <div class="uk-width-1-2@s">
            <label class="uk-form-label">Nome Completo</label>
            <div class="uk-form-controls">
                <input class="uk-input" asp-for="Input.FullName" required />
            </div>
        </div>
        <div class="uk-width-1-2@s">
            <label class="uk-form-label">E-mail</label>
            <div class="uk-form-controls">
                <input class="uk-input" type="email" asp-for="Input.Email" required />
            </div>
        </div>
        <div class="uk-width-1-2@s">
            <label class="uk-form-label">Data de Nascimento</label>
            <div class="uk-form-controls">
                <input class="uk-input" type="date" asp-for="Input.BirthDate" required />
            </div>
        </div>
        <div class="uk-width-1-2@s">
            <label class="uk-form-label">Telefone Fixo</label>
            <div class="uk-form-controls">
                <input class="uk-input" asp-for="Input.LandlinePhone" />
            </div>
        </div>
        <div class="uk-width-1-2@s">
            <label class="uk-form-label">Telefone Celular</label>
            <div class="uk-form-controls">
                <input class="uk-input" asp-for="Input.MobilePhone" required />
            </div>
        </div>
        <div class="uk-width-1-2@s">
            <label class="uk-form-label">Endereço</label>
            <div class="uk-form-controls">
                <input class="uk-input" asp-for="Input.Address" required />
            </div>
        </div>
        <div class="uk-width-1-2@s">
            <label class="uk-form-label">URL da Foto</label>
            <div class="uk-form-controls">
                <input class="uk-input" asp-for="Input.PhotoUrl" />
            </div>
        </div>
        <div class="uk-width-1-2@s">
            <label class="uk-form-label">Senha Provisória</label>
            <div class="uk-form-controls">
                <input class="uk-input" type="password" asp-for="Input.Password" required />
            </div>
        </div>
        <div class="uk-width-1-1 uk-margin-top">
            <label><input class="uk-checkbox" type="checkbox" asp-for="Input.IsManager"> Este usuário é um Gestor</label>
        </div>
        
        <div class="uk-width-1-1 uk-margin-top">
            <button class="uk-button uk-button-primary" type="submit">Salvar Usuário</button>
        </div>
    </form>
</div>

@page "/Users"
@model LeveInvestimentos.Web.Pages.Users.IndexModel
@{
    ViewData["Title"] = "Usuários";
}

<div class="uk-flex uk-flex-between uk-flex-middle uk-margin-bottom">
    <h2 class="text-gradient uk-margin-remove-bottom">Usuários da Equipe</h2>
    <a href="/Users/Create" class="uk-button uk-button-primary">
        <span uk-icon="icon: plus"></span> Novo Usuário
    </a>
</div>

<div class="glass-card uk-card uk-card-body uk-overflow-auto">
    <table class="uk-table uk-table-striped uk-table-hover uk-table-middle">
        <thead>
            <tr>
                <th>Nome</th>
                <th>E-mail</th>
                <th>Telefone Celular</th>
                <th>Perfil</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model.Users)
            {
                <tr>
                    <td class="uk-text-bold">@user.FullName</td>
                    <td>@user.Email</td>
                    <td>@user.MobilePhone</td>
                    <td>
                        @if(user.Role == LeveInvestimentos.Domain.Enums.UserRole.Manager)
                        {
                            <span class="uk-label uk-label-warning"><span uk-icon="icon: star"></span> Gestor</span>
                        }
                        else
                        {
                            <span class="uk-label"><span uk-icon="icon: user"></span> Comum</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

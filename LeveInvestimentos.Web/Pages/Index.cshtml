@page "/"
@model IndexModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="glass-card uk-card uk-card-body uk-margin-bottom">
    <h2 class="text-gradient uk-margin-remove-bottom">Dashboard</h2>
    <p class="uk-text-muted uk-margin-small-top">Bem-vindo ao LeveInvestimentos! Resumo das atividades.</p>
</div>

@if (Model.IsManager)
{
    <!-- Manger Dashboard -->
    <div class="uk-grid-match uk-child-width-1-3@m uk-margin-bottom" uk-grid>
        <div>
            <div class="glass-card uk-card uk-card-body">
                <h3 class="uk-card-title uk-text-bold"><span class="icon-primary" uk-icon="icon: users; ratio: 1.2"></span> Total Usuários</h3>
                <h1 class="text-gradient uk-heading-medium uk-margin-remove">@Model.TotalUsers</h1>
            </div>
        </div>
        <div>
            <div class="glass-card uk-card uk-card-body">
                <h3 class="uk-card-title uk-text-bold"><span class="icon-secondary" uk-icon="icon: list; ratio: 1.2"></span> Tarefas Equipe</h3>
                <h1 class="text-gradient uk-heading-medium uk-margin-remove">@Model.TotalTeamTasks</h1>
            </div>
        </div>
        <div>
            <div class="glass-card uk-card uk-card-body">
                <h3 class="uk-card-title uk-text-bold"><span class="uk-text-success" uk-icon="icon: check; ratio: 1.2"></span> Conclusão</h3>
                <h1 class="uk-text-success uk-heading-medium uk-margin-remove">@Model.CompletionPercentage%</h1>
            </div>
        </div>
    </div>

    <div class="uk-grid-match uk-child-width-1-2@m" uk-grid>
        <div>
            <div class="glass-card uk-card uk-card-body">
                <h3 class="uk-card-title uk-text-bold">Desempenho por Usuário</h3>
                <div class="uk-overflow-auto">
                    <table class="uk-table uk-table-hover uk-table-middle">
                        <thead>
                            <tr>
                                <th>Usuário</th>
                                <th>Tarefas</th>
                                <th>Concluídas</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var perf in Model.UserPerformance)
                            {
                                <tr>
                                    <td class="uk-text-bold">@perf.Key</td>
                                    <td><span class="uk-badge">@perf.Value.Total</span></td>
                                    <td><span class="uk-badge uk-label-success">@perf.Value.Completed</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        <div>
            <div class="glass-card uk-card uk-card-body">
                <h3 class="uk-card-title uk-text-bold">Status das Tarefas</h3>
                <div style="max-height: 300px; display: flex; justify-content: center;">
                    <canvas id="tasksChart"></canvas>
                </div>
            </div>
        </div>
    </div>
}
else
{
    <!-- Common User Dashboard -->
    
    @if (Model.DueTodayAlerts.Any() || Model.OverdueAlerts.Any())
    {
        <div class="uk-alert-warning glass-card uk-margin-bottom" uk-alert>
            <a class="uk-alert-close" uk-close></a>
            <h4 class="uk-text-warning uk-text-bold"><span uk-icon="icon: warning"></span> Atenção!</h4>
            <ul class="uk-list uk-list-disc uk-list-primary">
                @foreach(var alert in Model.OverdueAlerts)
                {
                    <li><strong>Atrasada:</strong> @alert.Description (Venceu em @alert.DueDate.ToString("dd/MM/yyyy"))</li>
                }
                @foreach(var alert in Model.DueTodayAlerts)
                {
                    <li><strong>Vence Hoje:</strong> @alert.Description</li>
                }
            </ul>
        </div>
    }

    <div class="uk-grid-match uk-child-width-1-4@m uk-margin-bottom" uk-grid>
        <div>
            <div class="glass-card uk-card uk-card-body uk-text-center">
                <h4 class="uk-text-muted uk-margin-remove uk-text-uppercase uk-text-small uk-text-bold">Total</h4>
                <h2 class="uk-margin-small-top text-gradient">@Model.TotalTasks</h2>
            </div>
        </div>
        <div>
            <div class="glass-card uk-card uk-card-body uk-text-center">
                <h4 class="uk-text-muted uk-margin-remove uk-text-uppercase uk-text-small uk-text-bold">Pendentes</h4>
                <h2 class="uk-margin-small-top uk-text-warning">@Model.PendingTasks</h2>
            </div>
        </div>
        <div>
            <div class="glass-card uk-card uk-card-body uk-text-center">
                <h4 class="uk-text-muted uk-margin-remove uk-text-uppercase uk-text-small uk-text-bold">Concluídas</h4>
                <h2 class="uk-margin-small-top uk-text-success">@Model.CompletedTasks</h2>
            </div>
        </div>
        <div>
            <div class="glass-card uk-card uk-card-body uk-text-center">
                <h4 class="uk-text-muted uk-margin-remove uk-text-uppercase uk-text-small uk-text-bold">Atrasadas</h4>
                <h2 class="uk-margin-small-top uk-text-danger">@Model.OverdueTasks</h2>
            </div>
        </div>
    </div>

    <div class="glass-card uk-card uk-card-body">
        <h3 class="uk-card-title uk-text-bold">Tarefas Recentes</h3>
        @if (Model.RecentTasks.Any())
        {
            <ul class="uk-list uk-list-divider">
                @foreach(var task in Model.RecentTasks)
                {
                    <li>
                        <div class="uk-flex uk-flex-between uk-flex-middle">
                            <span class="uk-text-medium">@task.Description</span>
                            <span class="uk-label @(task.Status == LeveInvestimentos.Domain.Enums.AppTaskStatus.Completed ? "uk-label-success" : "uk-label-warning")">
                                @task.Status.ToString()
                            </span>
                        </div>
                    </li>
                }
            </ul>
            <div class="uk-margin-top">
                <a href="/Tasks" class="uk-button uk-button-default">Ver todas as tarefas</a>
            </div>
        }
        else
        {
            <p class="uk-text-muted">Nenhuma tarefa recente.</p>
        }
    </div>
}

@section Scripts {
    @if (Model.IsManager)
    {
        <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
        <script>
            document.addEventListener("DOMContentLoaded", function() {
                var ctx = document.getElementById('tasksChart').getContext('2d');
                var tasksChart = new Chart(ctx, {
                    type: 'doughnut',
                    data: {
                        labels: ['Pendentes', 'Concluídas'],
                        datasets: [{
                            data: [@Model.PendingChartData, @Model.CompletedChartData],
                            backgroundColor: [
                                'rgba(245, 158, 11, 0.8)', // warning orange
                                'rgba(16, 185, 129, 0.8)'  // success green
                            ],
                            borderColor: [
                                'rgba(245, 158, 11, 1)',
                                'rgba(16, 185, 129, 1)'
                            ],
                            borderWidth: 2,
                            hoverOffset: 4
                        }]
                    },
                    options: {
                        responsive: true,
                        cutout: '70%',
                        plugins: {
                            legend: {
                                position: 'bottom',
                                labels: {
                                    font: { family: 'Inter', size: 14 }
                                }
                            }
                        }
                    }
                });
            });
        </script>
    }
}

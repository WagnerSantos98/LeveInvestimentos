@page "/Tasks"
@model LeveInvestimentos.Web.Pages.Tasks.IndexModel
@{
    ViewData["Title"] = "Tarefas";
}

<div class="uk-flex uk-flex-between uk-flex-middle uk-margin-bottom">
    <h2 class="uk-margin-remove text-gradient">Tarefas</h2>

    @if (User.HasClaim(System.Security.Claims.ClaimTypes.Role, "Manager"))
    {
        <a href="/Tasks/Create" class="uk-button uk-button-primary">
            <span uk-icon="icon: plus"></span> Nova Tarefa
        </a>
    }
</div>

<ul uk-tab>
    <li><a href="#" class="uk-text-bold">Minhas Tarefas</a></li>
    @if (User.HasClaim(System.Security.Claims.ClaimTypes.Role, "Manager"))
    {
        <li><a href="#" class="uk-text-bold">Criadas por Mim</a></li>
    }
</ul>

<ul class="uk-switcher uk-margin">

    <!-- ================= MINHAS TAREFAS ================= -->
    <li>
        <div class="glass-card uk-card uk-card-body uk-overflow-auto">
            <table class="uk-table uk-table-hover uk-table-middle">
                <thead>
                    <tr>
                        <th>Descrição</th>
                        <th>Criador</th>
                        <th>Data</th>
                        <th>Status</th>
                        <th class="uk-text-center">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var task in Model.AssignedTasks)
                    {
                        <tr>
                            <td class="uk-text-bold">@task.Description</td>
                            <td>@task.Creator?.FullName</td>
                            <td>@task.DueDate.ToString("dd/MM/yyyy")</td>

                            <!-- STATUS -->
                            <td>
                                @if (task.Status == LeveInvestimentos.Domain.Enums.AppTaskStatus.Pending)
                                {
                                    <span class="uk-label uk-label-warning">Pendente</span>
                                }
                                else
                                {
                                    <span class="uk-label uk-label-success">Concluída</span>
                                }
                            </td>

                            <!-- AÇÕES -->
                            <td class="uk-text-center">
                                <div class="uk-button-group">

                                    <!-- VER -->
                                    <a href="/Tasks/Details/@task.Id"
                                       class="uk-button uk-button-small uk-button-default">
                                        Ver
                                    </a>

                                    <!-- EDITAR -->
                                    <a href="/Tasks/Edit/@task.Id"
                                       class="uk-button uk-button-small uk-button-default">
                                        Editar
                                    </a>

                                    <!-- CONCLUIR -->
                                    @if (task.Status == LeveInvestimentos.Domain.Enums.AppTaskStatus.Pending)
                                    {
                                        <form method="post"
                                              asp-page-handler="Complete"
                                              asp-route-id="@task.Id"
                                              style="display:inline;">
                                            <button class="uk-button uk-button-small uk-button-primary">
                                                Concluir
                                            </button>
                                        </form>
                                    }
                                    else
                                    {
                                        <!-- REABRIR -->
                                        <form method="post"
                                              asp-page-handler="Reopen"
                                              asp-route-id="@task.Id"
                                              style="display:inline;">
                                            <button class="uk-button uk-button-small uk-button-default">
                                                Reabrir
                                            </button>
                                        </form>
                                    }

                                    <!-- EXCLUIR (SÓ MANAGER) -->
                                    @if (User.HasClaim(System.Security.Claims.ClaimTypes.Role, "Manager"))
                                    {
                                        <form method="post"
                                              asp-page-handler="Delete"
                                              asp-route-id="@task.Id"
                                              style="display:inline;"
                                              onsubmit="return confirm('Deseja realmente excluir esta tarefa?');">
                                            <button class="uk-button uk-button-small uk-button-danger">
                                                <span uk-icon="icon: trash"></span>
                                            </button>
                                        </form>
                                    }

                                </div>
                            </td>
                        </tr>
                    }

                    @if (!Model.AssignedTasks.Any())
                    {
                        <tr>
                            <td colspan="5" class="uk-text-center uk-text-muted">
                                Nenhuma tarefa encontrada.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </li>

    <!-- ================= CRIADAS POR MIM ================= -->
    @if (User.HasClaim(System.Security.Claims.ClaimTypes.Role, "Manager"))
    {
        <li>
            <div class="glass-card uk-card uk-card-body uk-overflow-auto">
                <table class="uk-table uk-table-hover uk-table-middle">
                    <thead>
                        <tr>
                            <th>Descrição</th>
                            <th>Responsável</th>
                            <th>Data</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var task in Model.CreatedTasks)
                        {
                            <tr>
                                <td class="uk-text-bold">@task.Description</td>
                                <td>@task.Assignee?.FullName</td>
                                <td>@task.DueDate.ToString("dd/MM/yyyy")</td>

                                <td>
                                    @if (task.Status == LeveInvestimentos.Domain.Enums.AppTaskStatus.Pending)
                                    {
                                        <span class="uk-label uk-label-warning">Pendente</span>
                                    }
                                    else
                                    {
                                        <span class="uk-label uk-label-success">Concluída</span>
                                    }
                                </td>
                            </tr>
                        }

                        @if (!Model.CreatedTasks.Any())
                        {
                            <tr>
                                <td colspan="4" class="uk-text-center uk-text-muted">
                                    Nenhuma tarefa criada.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </li>
    }
</ul>